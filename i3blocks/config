[wifi]
command=~/.config/i3blocks/scripts/wifi.sh
interval=30
LABEL=WIFI

[battery]
command=~/.config/i3blocks/scripts/battery.sh
interval=30
LABEL=BAT

[volume]
command=~/.config/i3blocks/scripts/volume.sh
interval=1
persist=true
LABEL=VOL

[cpu]
command=~/.config/i3blocks/scripts/cpu.sh
interval=3
REFRESH_TIME=1
LABEL=CPU 

[ram]
command=~/.config/i3blocks/scripts/ram.sh
interval=3
LABEL=RAM

[date]
command=~/.config/i3blocks/scripts/date.sh
interval=60
LABEL=DATE
